{
  "name": "engram-memory",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "engram": "./dist/cli.js"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
